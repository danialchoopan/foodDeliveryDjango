# Django Settings
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=on
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DB_NAME=snapfood_db
DB_USER=snapfood_user
DB_PASSWORD=snapfood_password
DB_HOST=localhost
DB_PORT=5432

# Redis (for Celery - optional but recommended)
REDIS_URL=redis://localhost:6379/0

# JWT / Token Auth
JWT_SECRET_KEY=your-jwt-secret-key
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=1

# Geolocation (for distance calculation)
DEFAULT_LATITUDE=35.6892
DEFAULT_LONGITUDE=51.3890
DELIVERY_BASE_FEE=5000
DELIVERY_FEE_PER_KM=2000

# Peak time pricing
PEAK_TIME_START=12
PEAK_TIME_END=14
PEAK_TIME_MULTIPLIER=1.5